{% extends 'layouts/auth.j2' %}

{% block page_content %}
<div class="d-flex flex-wrap gap-2 justify-content-between align-items-center mb-3">
    <div class="small text-muted">
        {{ _("AI snapshot (skeleton edge serverda chiziladi). JSON bo'lsa qo'shimcha overlay.") }}
    </div>
    <div class="d-flex gap-2">
        <span class="status-pill online" data-ai-status>AI</span>
        <a href="{{ live_preview_url }}" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-play-fill"></i> {{ _("Live video") }}
        </a>
        <a href="{{ url('camera:list', object.hall_id) }}" class="btn btn-sm btn-outline-primary">
            {{ _("Orqaga") }}
        </a>
    </div>
</div>

<div class="ai-preview-shell position-relative" id="ai-preview-root">
    <img data-ai-img class="w-100 d-block" alt="{{ object.name }}">
    <canvas class="ai-preview-overlay position-absolute top-0 start-0 w-100 h-100" style="display:none; pointer-events:none;"></canvas>
    <div class="ai-preview-loading">
        <div class="spinner-border spinner-border-sm"></div>
        <span class="ms-2">{{ _("Yuklanmoqda...") }}</span>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script src="{{ static('js/camera-ai-preview.js') }}?{{ STATIC_VERSION }}"></script>
<script>
document.addEventListener("DOMContentLoaded", function () {
    const root = document.querySelector("#ai-preview-root");
    initAiPreview(root, {
        imageUrl: "{{ preview_url }}",
        dataUrl: "{{ preview_url }}",
        interval: 1500,
        useAi: {{ 'true' if object.use_ai else 'false' }},
    });
    root.querySelector(".ai-preview-loading")?.remove();
});
</script>
{% endblock %}
