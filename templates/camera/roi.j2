{% extends 'layouts/auth.j2' %}

{% block page_content %}
<div class="app-page-card">
    <div class="d-inline-block">
        <div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
            <div class="btn-group" id="id_buttons">
                <button type="button" class="btn btn-primary btn-sm" data-type="0"
                        data-label="{{ _("Zona nomi") }}">{{ _("Sanash zonasi") }}</button>
            </div>
            <div id="id_json_roi" class="ms-2 text-muted small"></div>
            <a href="?save_frame=1" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-cloud-download me-1"></i>{{ _("Rasmni edge dan yuklash") }}
            </a>
            <button type="button" class="btn btn-primary ms-auto btn-sm" id="id_btn_save">
                <i class="bi bi-floppy-fill me-1"></i>{{ _("Saqlash") }}
            </button>
        </div>
        <div class="border rounded overflow-hidden d-inline-block">
            <div id="id_loading" class="p-5 text-center">
                <div class="spinner-border"></div>
                <p class="small text-muted mt-2 mb-0">{{ _("Kamera rasmi yuklanmoqda...") }}</p>
            </div>
            <div class="position-relative d-none" id="id_roi_canvas_wrap">
                <div class="position-absolute start-0 top-0 bottom-0 end-0 contain-image"
                     id="id-roi-bg"
                     data-frame-url="{{ frame_url }}"></div>
                <canvas id="id-camera-roi" class="w-100"></canvas>
            </div>
        </div>
        {% if not has_saved_screenshot %}
            <p class="small text-warning mt-2 mb-0">
                {{ _("Saqlangan screenshot yo'q — yuqoridagi tugma yoki kamera ro'yxatida «Rasmlarni yangilash» ishlating.") }}
            </p>
        {% endif %}

        <div class="mt-3">
            <label class="form-label small text-muted" for="id_input_load_json">{{ _("ROI json") }}</label>
            <input type="file" class="form-control" id="id_input_load_json" accept=".json" multiple>
        </div>
    </div>
</div>

    <div class="modal fade" tabindex="-1" id="id_assign_modal">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form method="post" action="" autocomplete="off">
                        <label for="id_assign_input" class="control-label"></label>
                        <input type="text" class="form-control" id="id_assign_input">
                        <div class="mt-3">
                            <button type="submit" class="btn btn-primary">{{ _("Saqlash") }}</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block extra_js %}
    <script type="application/json" id="id_saved">{{ object.roi|tojson }}</script>
    <script src="https://cdn.jsdelivr.net/npm/fabric@6.9.1/dist/index.min.js"></script>
    <script src="{{ static("js/camera-roi.min.js") }}?{{ STATIC_VERSION }}"></script>
    <script>
    document.addEventListener("DOMContentLoaded", function () {
        const bg = document.querySelector("#id-roi-bg");
        const frameUrl = bg?.dataset.frameUrl;
        if (!bg || !frameUrl) return;
        const img = new Image();
        img.onload = function () {
            bg.style.backgroundImage = `url('${frameUrl}&_=${Date.now()}')`;
        };
        img.onerror = function () {
            const loading = document.querySelector("#id_loading");
            if (loading) {
                loading.innerHTML = '<p class="text-danger small">{{ _("Rasm olinmadi. Token, login/parol va edge serverni tekshiring.") }}</p>';
            }
        };
        img.src = frameUrl + "&_=" + Date.now();
    });
    </script>
{% endblock %}
