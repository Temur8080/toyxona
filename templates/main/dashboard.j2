{% extends 'layouts/auth.j2' %}

{% block page_content %}
<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-card-icon primary"><i class="bi bi-people-fill"></i></div>
        <div>
            <div class="stat-card-value">{{ total_people|intcomma }}</div>
            <div class="stat-card-label">{{ _("Jami odamlar soni") }}</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-card-icon success"><i class="bi bi-building"></i></div>
        <div>
            <div class="stat-card-value">{{ halls_online }}/{{ halls_total }}</div>
            <div class="stat-card-label">{{ _("Onlayn toyxonalar") }}</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-card-icon warning"><i class="bi bi-camera-video-fill"></i></div>
        <div>
            <div class="stat-card-value">{{ camera_stats.online|default(0) }}/{{ camera_stats.total|default(0) }}</div>
            <div class="stat-card-label">{{ _("Onlayn kameralar") }}</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-card-icon danger"><i class="bi bi-clock-history"></i></div>
        <div>
            <div class="stat-card-value">{{ today_records|intcomma }}</div>
            <div class="stat-card-label">{{ _("Bugungi yozuvlar") }}</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-card-icon warning"><i class="bi bi-balloon-fill"></i></div>
        <div>
            <div class="stat-card-value">{{ active_toys_count|intcomma }}</div>
            <div class="stat-card-label">{{ _("Faol toy") }} (≥{{ toy_threshold }})</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="app-page-card h-100">
            <h2 class="section-title">{{ _("Toyxonalar") }}</h2>
            {% if halls %}
                <div class="hall-grid">
                    {% for hall in halls %}
                        <a href="{{ url('counting:dashboard', hall.id) }}" class="hall-card">
                            <div class="hall-card-head">
                                <div>
                                    <h3 class="hall-card-title">{{ hall }}</h3>
                                    <div class="hall-card-meta">{{ hall.district.region.name }} · {{ hall.district.name }}</div>
                                </div>
                                <div class="d-flex flex-column align-items-end gap-1">
                                    {% if hall.is_toy_now %}
                                        <span class="badge text-bg-warning">{{ _("Toy") }}</span>
                                    {% endif %}
                                    <span class="status-pill {{ 'online' if hall.is_online else 'offline' }}">
                                        <i class="bi bi-circle-fill" style="font-size:.5rem"></i>
                                        {{ _("Online") if hall.is_online else _("Offline") }}
                                    </span>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between align-items-end">
                                <div>
                                    <div class="stat-card-value stat-card-value--sm">{{ hall.latest_count|default(0)|intcomma }}</div>
                                    <div class="stat-card-label">{{ _("Hozirgi odamlar") }}</div>
                                </div>
                                {% if hall.max_capacity %}
                                    <div class="text-end">
                                        <div class="small text-muted">{{ _("Sig'im") }}: {{ hall.max_capacity|intcomma }}</div>
                                        {% if hall.fill_percent is not none %}
                                            <div class="small fw-semibold">{{ hall.fill_percent }}%</div>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                            {% if hall.fill_percent is not none %}
                                <div class="capacity-bar">
                                    <div class="capacity-bar-fill {% if hall.fill_percent > 90 %}danger{% elif hall.fill_percent > 70 %}warning{% endif %}"
                                         style="width: {{ hall.fill_percent if hall.fill_percent <= 100 else 100 }}%"></div>
                                </div>
                            {% endif %}
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <div class="empty-state">
                    <i class="bi bi-building"></i>
                    <p>{{ _("Ruxsat berilgan toyxona yo'q") }}</p>
                </div>
            {% endif %}
        </div>
    </div>

    <div class="col-lg-5">
        <div class="app-page-card h-100">
            <h2 class="section-title">{{ _("So'nggi faollik") }}</h2>
            {% if recent_activity %}
                <table class="data-table">
                    <thead>
                    <tr>
                        <th>{{ _("Toyxona") }}</th>
                        <th>{{ _("Odamlar") }}</th>
                        <th>{{ _("Vaqt") }}</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for row in recent_activity %}
                        <tr>
                            <td>{{ row.hall }}</td>
                            <td><strong>{{ row.count|intcomma }}</strong></td>
                            <td class="text-muted">{{ row.recorded_at|datetime_format }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <div class="empty-state">
                    <i class="bi bi-activity"></i>
                    <p>{{ _("Hali ma'lumot yo'q") }}</p>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
