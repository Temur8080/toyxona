{% extends 'layouts/auth.j2' %}

{% block page_content %}
<div class="d-flex flex-wrap gap-2 justify-content-between align-items-center mb-3">
    <div class="d-flex flex-wrap gap-2 align-items-center">
        {% if perms.camera.change_camera %}
            <a href="?load=true" class="btn btn-primary btn-sm">
                <i class="bi bi-cloud-download me-1"></i>{{ _("Kameralarni yuklash") }}
            </a>
            <button type="button" class="btn btn-outline-primary btn-sm" id="id_update_all">{{ _("Rasmlarni yangilash") }}</button>
            <a href="?o=true" class="btn btn-outline-primary btn-sm">{{ _("Onlaynlarni yangilash") }}</a>
            {% if camera_counts.inactive > 0 %}
                <a href="?activate_all=true" class="btn btn-outline-success btn-sm"
                   onclick="return confirm('{{ _('Barcha nofaol kameralarni faollashtirasizmi?') }}');">
                    {{ _("Barchasini faollashtirish") }} ({{ camera_counts.inactive }})
                </a>
            {% endif %}
        {% endif %}
        {% if show_all %}
            <a href="{{ url('camera:list', hall.id) }}" class="btn btn-outline-secondary btn-sm">{{ _("Faqat faollar") }}</a>
        {% else %}
            <a href="?show_all=true" class="btn btn-outline-secondary btn-sm">
                {{ _("Barchasi") }} ({{ camera_counts.total }})
            </a>
        {% endif %}
        <span class="small text-muted">
            {{ _("Faol") }}: {{ camera_counts.active }}
            {% if camera_counts.inactive %} · {{ _("Nofaol") }}: {{ camera_counts.inactive }}{% endif %}
        </span>
    </div>
    {% if updating %}
        <span class="status-pill online"><i class="bi bi-arrow-repeat"></i> {{ _("Yangilanmoqda...") }}</span>
    {% endif %}
</div>

<div class="camera-grid">
    {% for cam in object_list %}
        <article class="camera-card">
            <a href="{{ url('camera:preview-ai', cam.id) }}" class="camera-card-media">
                <img src="{% if cam.screenshot %}{{ cam.screenshot.url }}?{{ request.GET.t }}{% else %}{{ static('img/no-photo.png') }}{% endif %}"
                     {% if cam.use_ai and cam.is_online %}
                     data-ai-src="{{ url('camera:preview-ai', cam.id) }}?image=true"
                     data-ai-live="1"
                     {% endif %}
                     alt="{{ cam.name }}"
                     loading="lazy">
                {% if cam.use_ai %}
                    <span class="camera-card-badge"><i class="bi bi-person-arms-up"></i> AI</span>
                {% endif %}
            </a>
            <div class="camera-card-body">
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    {% if not cam.is_active %}
                        <span class="status-pill offline">{{ _("Nofaol") }}</span>
                    {% endif %}
                    <span class="status-pill {{ 'online' if cam.is_online else 'offline' }}">
                        {{ _("Online") if cam.is_online else _("Offline") }}
                    </span>
                </div>
                <h3 class="camera-card-title mt-2">{{ cam.name }}</h3>
                {% if cam.total_info %}<div class="small text-muted">{{ cam.total_info }}</div>{% endif %}
                {% if perms.camera.change_camera %}
                    <div class="d-flex gap-2 mt-2">
                        <a href="{{ url('camera:roi', cam.id) }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-bounding-box"></i> ROI
                        </a>
                        <a href="{{ url('camera:preview', cam.id) }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-play-fill"></i> Live
                        </a>
                    </div>
                {% endif %}
            </div>
        </article>
    {% else %}
        <div class="empty-state w-100">
            <i class="bi bi-camera-video-off"></i>
            <p>{{ _("Kamera topilmadi") }}</p>
            {% if perms.camera.change_camera %}
                <a href="?load=true" class="btn btn-primary btn-sm mt-2">{{ _("Edge serverdan yuklash") }}</a>
            {% endif %}
        </div>
    {% endfor %}
</div>
{% endblock %}

{% block extra_js %}
<script>
    document.querySelector("#id_update_all")?.addEventListener("click", function () {
        if (confirm("{{ _('Yangilansinmi?') }}")) window.location.href = "?u=true";
    });

    const aiQueue = [];
    let aiActive = 0;
    const AI_MAX_PARALLEL = 3;
    const AI_INTERVAL_MS = 12000;

    function pumpAiQueue() {
        while (aiActive < AI_MAX_PARALLEL && aiQueue.length) {
            const img = aiQueue.shift();
            const base = img.getAttribute("data-ai-src");
            if (!base) continue;
            aiActive++;
            fetch(`${base}&_=${Date.now()}`, {cache: "no-store"})
                .then(r => r.ok ? r.blob() : Promise.reject())
                .then(blob => {
                    const old = img.dataset.blobUrl;
                    img.src = URL.createObjectURL(blob);
                    if (old) URL.revokeObjectURL(old);
                    img.dataset.blobUrl = img.src;
                })
                .catch(() => {})
                .finally(() => {
                    aiActive--;
                    pumpAiQueue();
                });
        }
    }

    function queueVisibleAiThumbnails() {
        aiQueue.length = 0;
        document.querySelectorAll("img[data-ai-live]").forEach(img => {
            if (img.dataset.aiVisible === "1") aiQueue.push(img);
        });
        pumpAiQueue();
    }

    document.addEventListener("DOMContentLoaded", function () {
        const imgs = document.querySelectorAll("img[data-ai-live]");
        if (!imgs.length || !("IntersectionObserver" in window)) {
            imgs.forEach(img => { img.dataset.aiVisible = "1"; });
            queueVisibleAiThumbnails();
            setInterval(queueVisibleAiThumbnails, AI_INTERVAL_MS);
            return;
        }
        const obs = new IntersectionObserver(entries => {
            entries.forEach(e => {
                e.target.dataset.aiVisible = e.isIntersecting ? "1" : "0";
            });
            queueVisibleAiThumbnails();
        }, {rootMargin: "80px", threshold: 0.05});
        imgs.forEach(img => obs.observe(img));
        setInterval(queueVisibleAiThumbnails, AI_INTERVAL_MS);
    });
</script>
{% if updating %}
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const check = () => fetch("?check=true").then(r => r.text()).then(r => {
            if (r.toLowerCase() === "false") window.location.href = '?t=' + Date.now();
            else setTimeout(check, 2000);
        });
        setTimeout(check, 2000);
    });
</script>
{% endif %}
{% endblock %}
