{% extends 'layouts/auth.j2' %}

{% block page_content %}
<div class="video-shell">
    <div class="text-center p-5 text-white">
        <div class="spinner-border"></div>
        <div class="mt-3">{{ _("Video yuklanmoqda (MSE/MJPEG)...") }}</div>
        <p class="small text-white-50 mt-2 mb-0">
            {{ _("Agar ishlamasa: kamera login/parol, CONTROL_ACCESS_TOKEN, nginx reload.") }}
        </p>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script type="module" src="{{ static('vendor/go2rts/video-stream.min.js') }}?{{ STATIC_VERSION }}"></script>
<script data-stream-host="{{ stream_host|default('', true) }}" src="{{ static('js/camera-stream.js') }}?{{ STATIC_VERSION }}"></script>
<script>
document.addEventListener("DOMContentLoaded", function() {
    const shell = document.querySelector(".video-shell");
    shell.innerHTML = "";
    const wrap = document.createElement("div");
    wrap.className = "w-100";
    shell.appendChild(wrap);
    init_stream("{{ (object.hall_id ~ ':' ~ object.device_sn)|sign }}", wrap);
});
</script>
{% endblock %}
